# Breachly environment variables
# Copy to `.env` and fill in. Never commit `.env`.

# --- Client (safe to ship; these are public-by-design Supabase values) ---
# When true, the Check screen uses local mock data instead of calling the
# Edge Function. Default true so the app runs with zero backend setup.
EXPO_PUBLIC_USE_MOCK=true

# Your Supabase project URL + anon key. The anon key is public by design;
# the HIBP secret key lives ONLY in the Edge Function (see below).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Edge Function secrets (server-side ONLY — never bundle into the app) ---
# Set with: supabase secrets set HIBP_API_KEY=xxxx
# HIBP_API_KEY=
